  "keyFeatures": [
    "Event-driven payouts with customizable trigger conditions",
    "Scheduled payouts with flexible timing options",
    "Team member management with email-based onboarding",
    "On-chain spending limits (per-transaction, per-period, call frequency)",
    "Smart wallet integration via Privy (EOA + kernel smart wallet)",
    "USDC staking with yield through Blend",
    "ACH and wire off-ramp via Plaid",
    "KYC/KYB identity verification",
    "Transaction history and audit trail",
    "ArcherAgentEndpoint smart contract for trustless rule enforcement"
  ],
  "publicApiSurface": [
    "GET/POST /account",
    "GET/POST/PATCH/DELETE /person",
    "GET/POST/PATCH/DELETE /event_payout",
    "GET/POST/DELETE /scheduled_payout",
    "GET /transaction_history",
